@{
    var currentArea = Convert.ToString(ViewContext.RouteData.Values["area"]);
    var currentController = Convert.ToString(ViewContext.RouteData.Values["controller"]);
    var currentAction = Convert.ToString(ViewContext.RouteData.Values["action"]);

    var isDashboardActive = string.IsNullOrWhiteSpace(currentArea)
        && string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase);

    var isAdminScopeActive = string.Equals(currentArea, "Admin", StringComparison.OrdinalIgnoreCase);

    var isStoreListActive = isAdminScopeActive
        && string.Equals(currentController, "StoreList", StringComparison.OrdinalIgnoreCase);

    var isHRScopeActive = string.Equals(currentArea, "HR", StringComparison.OrdinalIgnoreCase);

    var isEmployeeListActive = isHRScopeActive
        && string.Equals(currentController, "EmployeeList", StringComparison.OrdinalIgnoreCase);

    var isEmployeeDepartmentActive = isHRScopeActive
        && string.Equals(currentController, "EmployeeDepartment", StringComparison.OrdinalIgnoreCase);
}

<aside class="crm-sidebar" id="sidebar">

    <div class="sidebar-brand sidebar-brand-logo">
        <a asp-controller="Home" asp-action="Index" class="brand-image-link">
            <img src="~/images/logo-default-258x116-1.png.webp"
                 alt="CRM Admin Logo"
                 class="brand-image" />
        </a>
    </div>

    <div class="sidebar-scroll">

        <div class="menu-label">Overview</div>

        <a asp-area=""
           asp-controller="Home"
           asp-action="Index"
           class="menu-link @(isDashboardActive ? "active" : "")">
            <i class="bi bi-speedometer2"></i>
            <span>Dashboard</span>
        </a>

        <div class="menu-label">Admin</div>

        <button class="menu-toggle @(isAdminScopeActive ? "active" : "")"
                data-bs-toggle="collapse"
                data-bs-target="#AdminAdminMenu"
                aria-expanded="@(isAdminScopeActive.ToString().ToLower())">
            <i class="bi bi-person-gear"></i>
            <span>Admin</span>
            <i class="bi bi-chevron-right menu-arrow"></i>
        </button>

        <div class="collapse @(isAdminScopeActive ? "show" : "")" id="AdminAdminMenu">
            <div class="submenu">
                <a asp-area="Admin"
                   asp-controller="StoreList"
                   asp-action="Index"
                   class="@(isStoreListActive ? "active" : "")">Store List</a>

                <a href="javascript:void(0);">Reason Codes</a>
                <a href="javascript:void(0);">Audit Log</a>
            </div>
        </div>

