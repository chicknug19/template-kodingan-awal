@{
    ViewData["Title"] = "Event List";
    ViewData["PageTitle"] = "Event List";
    ViewData["PageSubtitle"] = "Manage event data";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div ng-app="eventListApp"
     ng-controller="EventListController"
     ng-cloak>

    @Html.AntiForgeryToken()

    <div class="admin-page-header mb-4">
        <div>
            <span class="admin-eyebrow">Admin</span>
            <h3>Event List</h3>
            <p>Manage event master data including name, code, and description.</p>
        </div>

        <div class="admin-page-actions">
            <a href="/Event/EventAdd/EventAddPage"
               class="btn btn-main">
                <i class="bi bi-plus-lg me-2"></i>
                Add
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="alert alert-success alert-dismissible fade show" role="alert" ng-if="alert.type === 'success'">
        <span ng-bind="alert.message"></span>
        <button type="button" class="btn-close" ng-click="clearAlert()"></button>
    </div>

    <div class="alert alert-danger alert-dismissible fade show" role="alert" ng-if="alert.type === 'danger'">
        <span ng-bind="alert.message"></span>
        <button type="button" class="btn-close" ng-click="clearAlert()"></button>
    </div>

    <div class="crm-card mb-4">
        <div class="section-title">
            <h5>Filter Event</h5>
        </div>

        <form ng-submit="searchEvents()">
            <div class="row g-3 align-items-end">
                <div class="col-xl-6 col-md-6">
                    <label class="form-label admin-form-label">Keyword</label>
                    <div class="admin-input-icon">
                        <i class="bi bi-search"></i>
                        <input type="text"
                               ng-model="filter.keyword"
                               class="form-control"
                               placeholder="Search by event name, code, or description" />
                    </div>
                </div>

                <div class="col-xl-6 col-md-12 d-flex gap-2">
                    <button type="submit"
                            class="btn btn-main flex-fill"
                            ng-disabled="isBusy()">
                        <i class="bi bi-search me-2"></i>
                        Search
                    </button>

                    <button type="button"
                            class="btn btn-soft"
                            ng-click="resetFilter()"
                            ng-disabled="isBusy()">
                        Reset
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="crm-card">
        <div class="store-table-header">
            <div>
                <h5>Event Data</h5>
                <p>
                    Showing
                    <span ng-bind="events.length"></span>
                    event record(s)
                </p>
            </div>

            <button type="button"
                    class="btn btn-soft btn-sm"
                    ng-click="loadEvents(true)"
                    ng-disabled="isBusy()">
                <i class="bi bi-arrow-clockwise me-1" ng-class="{ 'store-spin': isBusy() }"></i>
                Refresh
            </button>
        </div>

        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Event Id</th>
                        <th>Event Name</th>
                        <th>Code</th>
                        <th>Description</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>

                <tbody>
                    <tr ng-repeat="event in events track by event.eventId">
                        <td data-label="Event Id">
                            <span ng-bind="event.eventId || '-'"></span>
                        </td>

                        <td data-label="Event Name">
                            <span ng-bind="event.eventName || '-'"></span>
                        </td>

                        <td data-label="Code">
                            <span ng-bind="event.code || '-'"></span>
                        </td>

                        <td data-label="Description">
                            <span ng-bind="event.description || '-'"></span>
                        </td>

                        <td class="text-center action-sticky" data-label="Action">
                            <div class="table-action-icons">
                                <a href="/Event/EventEdit/EventEditPage?id={{ event.eventId }}"
                                   class="btn-action-icon btn-edit"
                                   title="Edit">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                            </div>
                        </td>
                    </tr>

                    <tr ng-if="events.length === 0 && !isLoading">
                        <td colspan="5">
                            <div class="admin-empty-state">
                                <i class="bi bi-inbox"></i>
                                <h5>No events found</h5>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="delete-confirm-backdrop"
         ng-if="deleteModal.visible"
         ng-click="closeDeleteConfirmation()">

        <div class="delete-confirm-modal"
             ng-click="$event.stopPropagation()">

            <div class="delete-confirm-header">
                <div class="delete-confirm-icon">
                    <i class="bi bi-trash3"></i>
                </div>

                <div>
                    <h5>Delete Event?</h5>
                    <p>This action will remove the event record.</p>
                </div>

                <button type="button"
                        class="delete-confirm-close"
                        ng-click="closeDeleteConfirmation()"
                        ng-disabled="isDeleting">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="delete-confirm-body">
                <div class="delete-store-preview">
                    <div class="delete-store-avatar">
                        <i class="bi bi-calendar-event"></i>
                    </div>

                    <div class="delete-store-info">
                        <strong ng-bind="deleteModal.event.eventName || '-'"></strong>
                        <div>
                            <span ng-if="deleteModal.event.code">
                                {{ deleteModal.event.code }}
                            </span>
                        </div>
                    </div>
                </div>

                <div class="delete-warning-box">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>
                        Are you sure you want to delete this event?
                    </span>
                </div>

                <div class="delete-error-box" ng-if="deleteModal.errorMessage">
                    <i class="bi bi-x-circle"></i>
                    <span ng-bind="deleteModal.errorMessage"></span>
                </div>
            </div>

            <div class="delete-confirm-actions">
                <button type="button"
                        class="btn btn-soft"
                        ng-click="closeDeleteConfirmation()"
                        ng-disabled="isDeleting">
                    Cancel
                </button>

                <button type="button"
                        class="btn btn-delete-confirm"
                        ng-click="confirmDeleteEvent()"
                        ng-disabled="isDeleting">
                    <span class="spinner-border spinner-border-sm me-2"
                          ng-if="isDeleting"></span>
                    <i class="bi bi-trash3 me-2"
                       ng-if="!isDeleting"></i>
                    <span ng-if="!isDeleting">Yes, Delete Event</span>
                    <span ng-if="isDeleting">Deleting...</span>
                </button>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        (function () {
            'use strict';

            angular
                .module('eventListApp', [])
                .controller('EventListController', EventListController);

            EventListController.$inject = ['$scope', '$timeout', '$http'];

            function EventListController($scope, $timeout, $http) {
                var allEvents = [];

                $scope.filter = {
                    keyword: ''
                };

                $scope.sort = {
                    column: 'eventName',
                    direction: 'ASC'
                };

                $scope.changeSort = changeSort;
                $scope.isSorted = isSorted;
                $scope.getSortIcon = getSortIcon;
                $scope.events = [];
                $scope.isLoading = false;
                $scope.isDeleting = false;

                $scope.deleteModal = {
                    visible: false,
                    event: null,
                    errorMessage: ''
                };

                $scope.alert = {
                    type: '',
                    message: ''
                };

                $scope.loadEvents = loadEvents;
                $scope.searchEvents = searchEvents;
                $scope.resetFilter = resetFilter;
                $scope.openDeleteConfirmation = openDeleteConfirmation;
                $scope.closeDeleteConfirmation = closeDeleteConfirmation;
                $scope.confirmDeleteEvent = confirmDeleteEvent;
                $scope.clearAlert = clearAlert;
                $scope.isBusy = isBusy;

                loadEvents(true);

                function loadEvents() {
                    $scope.isLoading = true;
                    clearAlert();

                    $http.get('/Event/EventList/GetEventList', {
                        params: {
                            keyword: $scope.filter.keyword,
                            page: 1,
                            pageSize: 20
                        }
                    }).then(function (response) {
                        var payload = response.data || {};
                        allEvents = payload.data || [];

                        applyEventsFilter();
                        $scope.isLoading = false;
                    }).catch(function () {
                        allEvents = [];
                        $scope.events = [];
                        $scope.isLoading = false;
                        showAlert('danger', 'Failed to load event data.');
                    });
                }

                function applyEventsFilter() {
                    var filtered = allEvents;

                    if ($scope.filter.keyword) {
                        var keyword = $scope.filter.keyword.toLowerCase();

                        filtered = allEvents.filter(function (e) {
                            return (e.eventName || '').toLowerCase().includes(keyword) ||
                                   (e.code || '').toLowerCase().includes(keyword) ||
                                   (e.description || '').toLowerCase().includes(keyword);
                        });
                    }

                    $scope.events = filtered;
                    applyEventsSort();
                }

                function changeSort(column) {
                    if ($scope.sort.column === column) {
                        $scope.sort.direction = ($scope.sort.direction === 'ASC') ? 'DESC' : 'ASC';
                    } else {
                        $scope.sort.column = column;
                        $scope.sort.direction = 'ASC';
                    }

                    applyEventsSort();
                }

                function isSorted(column) {
                    return $scope.sort.column === column;
                }

                function getSortIcon(column) {
                    if (!isSorted(column)) {
                        return 'bi-arrow-down-up';
                    }

                    return $scope.sort.direction === 'ASC'
                        ? 'bi-arrow-up'
                        : 'bi-arrow-down';
                }

                function applyEventsSort() {
                    var sorted = angular.copy($scope.events || []);

                    sorted.sort(function (a, b) {
                        var left = (a[$scope.sort.column] || '').toString().toLowerCase();
                        var right = (b[$scope.sort.column] || '').toString().toLowerCase();

                        if (left < right) return $scope.sort.direction === 'ASC' ? -1 : 1;
                        if (left > right) return $scope.sort.direction === 'ASC' ? 1 : -1;
                        return 0;
                    });

                    $scope.events = sorted;
                }

                function searchEvents() {
                    if (isBusy()) {
                        return;
                    }

                    clearAlert();
                    applyEventsFilter();
                }

                function resetFilter() {
                    if (isBusy()) {
                        return;
                    }

                    clearAlert();
                    $scope.filter.keyword = '';
                    applyEventsFilter();
                }

                function openDeleteConfirmation(event) {
                    if (!event || !event.eventId) {
                        return;
                    }

                    clearAlert();
                    $scope.deleteModal.event = event;
                    $scope.deleteModal.errorMessage = '';
                    $scope.deleteModal.visible = true;
                }

                function closeDeleteConfirmation() {
                    if ($scope.isDeleting) {
                        return;
                    }

                    $scope.deleteModal.visible = false;
                    $scope.deleteModal.event = null;
                    $scope.deleteModal.errorMessage = '';
                }

                function confirmDeleteEvent() {
                    var eventToDelete = $scope.deleteModal.event;

                    if (!eventToDelete || !eventToDelete.eventId) {
                        closeDeleteConfirmation();
                        return;
                    }

                    $scope.isDeleting = true;
                    $scope.deleteModal.errorMessage = '';
                    clearAlert();

                    // NOTE: this is currently a client-side-only mock delete (no API call).
                    // Wire this up to a real DELETE endpoint, e.g.:
                    // $http.delete('/Event/EventList/DeleteEvent', { params: { id: eventToDelete.eventId } })
                    $timeout(function () {
                        var index = allEvents.findIndex(function (e) {
                            return e.eventId === eventToDelete.eventId;
                        });

                        if (index > -1) {
                            allEvents.splice(index, 1);
                        }

                        applyEventsFilter();

                        var successMessage = 'Event has been deleted successfully.';
                        $scope.deleteModal.visible = false;
                        $scope.deleteModal.event = null;
                        $scope.deleteModal.errorMessage = '';
                        $scope.isDeleting = false;

                        showAlert('success', successMessage);
                    }, 800);
                }

                function isBusy() {
                    return $scope.isLoading || $scope.isDeleting;
                }

                function showAlert(type, message) {
                    $scope.alert.type = type;
                    $scope.alert.message = message;

                    if (type === 'success') {
                        $timeout(function () {
                            clearAlert();
                        }, 3500);
                    }
                }

                function clearAlert() {
                    $scope.alert.type = '';
                    $scope.alert.message = '';
                }
            }
        })();
    </script>
}
