@{
    ViewData["Title"] = "Customer List";
    ViewData["PageTitle"] = "Customer List";
    ViewData["PageSubtitle"] = "Manage customer data";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div ng-app="customerListApp"
     ng-controller="CustomerListController"
     ng-cloak>

    @Html.AntiForgeryToken()

    <div class="admin-page-header mb-4">
        <div>
            <span class="admin-eyebrow">Admin</span>
            <h3>Customer List</h3>
            <p>Manage customer master data including name, address, and phone number.</p>
        </div>

        <div class="admin-page-actions">
            <a asp-area="Customer"
               asp-controller="CustomerAdd"
               asp-action="CustomerAddPage"
               class="btn btn-main">
                <i class="bi bi-plus-lg me-2"></i>
                Add
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="alert alert-success alert-dismissible fade show" role="alert" ng-if="alert.type === 'success'">
        <span ng-bind="alert.message"></span>
        <button type="button" class="btn-close" ng-click="clearAlert()"></button>
    </div>

    <div class="alert alert-danger alert-dismissible fade show" role="alert" ng-if="alert.type === 'danger'">
        <span ng-bind="alert.message"></span>
        <button type="button" class="btn-close" ng-click="clearAlert()"></button>
    </div>

    <div class="crm-card mb-4">
        <div class="section-title">
            <h5>Filter Customer</h5>
        </div>

        <form ng-submit="searchCustomers()">
            <div class="row g-3 align-items-end">
                <div class="col-xl-6 col-md-6">
                    <label class="form-label admin-form-label">Keyword</label>
                    <div class="admin-input-icon">
                        <i class="bi bi-search"></i>
                        <input type="text"
                               ng-model="filter.keyword"
                               class="form-control"
                               placeholder="Search by name, address, or phone" />
                    </div>
                </div>

                <div class="col-xl-6 col-md-12 d-flex gap-2">
                    <button type="submit"
                            class="btn btn-main flex-fill"
                            ng-disabled="isBusy()">
                        <i class="bi bi-search me-2"></i>
                        Search
                    </button>

                    <button type="button"
                            class="btn btn-soft"
                            ng-click="resetFilter()"
                            ng-disabled="isBusy()">
                        Reset
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="crm-card">
        <div class="store-table-header">
            <div>
                <h5>Customer Data</h5>
                <p>
                    Showing
                    <span ng-bind="customers.length"></span>
                    customer record(s)
                </p>
            </div>

            <button type="button"
                    class="btn btn-soft btn-sm"
                    ng-click="loadCustomers(true)"
                    ng-disabled="isBusy()">
                <i class="bi bi-arrow-clockwise me-1" ng-class="{ 'store-spin': isBusy() }"></i>
                Refresh
            </button>
        </div>

        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Address</th>
                        <th>Phone Number</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>

                <tbody>
                    <tr ng-repeat="customer in customers track by customer.customerID">
                        <td data-label="Full Name">
                            <span ng-bind="customer.fullName || '-'"></span>
                        </td>

                        <td data-label="Address">
                            <span ng-bind="customer.address1 || '-'"></span>
                        </td>

                        <td data-label="Phone Number">
                            <span ng-bind="customer.phoneNumber || '-'"></span>
                        </td>

                        <td class="text-end">
                            <div class="d-flex gap-2 justify-content-end">
                                <a href="#" class="btn btn-soft btn-sm">
                                    Edit
                                </a>
                                <button type="button" 
                                        class="btn btn-soft btn-sm"
                                        ng-click="openDeleteConfirmation(customer)">
                                    Delete
                                </button>
                            </div>
                        </td>
                    </tr>

                    <tr ng-if="customers.length === 0 && !isLoading">
                        <td colspan="4">
                            <div class="admin-empty-state">
                                <i class="bi bi-inbox"></i>
                                <h5>No customers found</h5>
                            </div>
                        </td>
                    </tr>

                    <tr ng-if="isLoading">
                        <td colspan="4">
                            <div class="text-center py-4">
                                <div class="spinner-border text-secondary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="delete-confirm-backdrop"
         ng-if="deleteModal.visible"
         ng-click="closeDeleteConfirmation()">

        <div class="delete-confirm-modal"
             ng-click="$event.stopPropagation()">

            <div class="delete-confirm-header">
                <div class="delete-confirm-icon">
                    <i class="bi bi-trash3"></i>
                </div>

                <div>
                    <h5>Delete Customer?</h5>
                    <p>This action will remove the customer record.</p>
                </div>

                <button type="button"
                        class="delete-confirm-close"
                        ng-click="closeDeleteConfirmation()"
                        ng-disabled="isDeleting">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="delete-confirm-body">
                <div class="delete-store-preview">
                    <div class="delete-store-avatar">
                        <i class="bi bi-person"></i>
                    </div>

                    <div class="delete-store-info">
                        <strong ng-bind="deleteModal.customer.fullName || '-'"></strong>
                        <div>
                            <span ng-if="deleteModal.customer.address1">
                                {{ deleteModal.customer.address1 }}
                            </span>
                        </div>
                    </div>
                </div>

                <div class="delete-warning-box">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>
                        Are you sure you want to delete this customer?
                    </span>
                </div>

                <div class="delete-error-box" ng-if="deleteModal.errorMessage">
                    <i class="bi bi-x-circle"></i>
                    <span ng-bind="deleteModal.errorMessage"></span>
                </div>
            </div>

            <div class="delete-confirm-actions">
                <button type="button"
                        class="btn btn-soft"
                        ng-click="closeDeleteConfirmation()"
                        ng-disabled="isDeleting">
                    Cancel
                </button>

                <button type="button"
                        class="btn btn-delete-confirm"
                        ng-click="confirmDeleteCustomer()"
                        ng-disabled="isDeleting">
                    <span class="spinner-border spinner-border-sm me-2"
                          ng-if="isDeleting"></span>
                    <i class="bi bi-trash3 me-2"
                       ng-if="!isDeleting"></i>
                    <span ng-if="!isDeleting">Yes, Delete Customer</span>
                    <span ng-if="isDeleting">Deleting...</span>
                </button>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        (function () {
            'use strict';

            angular
                .module('customerListApp', [])
                .controller('CustomerListController', CustomerListController);

            CustomerListController.$inject = ['$scope', '$timeout'];

            function CustomerListController($scope, $timeout) {
                // Dummy Data
                var dummyCustomers = [
                    {
                        customerID: 1,
                        fullName: 'John Doe',
                        address1: '123 Main Street, Apartment 4B',
                        phoneNumber: '+1-555-0101'
                    },
                    {
                        customerID: 2,
                        fullName: 'Jane Smith',
                        address1: '456 Oak Avenue, Suite 200',
                        phoneNumber: '+1-555-0102'
                    },
                    {
                        customerID: 3,
                        fullName: 'Michael Johnson',
                        address1: '789 Pine Road, Building C',
                        phoneNumber: '+1-555-0103'
                    },
                    {
                        customerID: 4,
                        fullName: 'Sarah Williams',
                        address1: '321 Elm Street, Floor 5',
                        phoneNumber: '+1-555-0104'
                    },
                    {
                        customerID: 5,
                        fullName: 'Robert Brown',
                        address1: '654 Maple Drive, Unit 10',
                        phoneNumber: '+1-555-0105'
                    }
                ];

                $scope.filter = {
                    keyword: ''
                };

                $scope.customers = [];
                $scope.isLoading = false;
                $scope.isDeleting = false;

                $scope.deleteModal = {
                    visible: false,
                    customer: null,
                    errorMessage: ''
                };

                $scope.alert = {
                    type: '',
                    message: ''
                };

                $scope.loadCustomers = loadCustomers;
                $scope.searchCustomers = searchCustomers;
                $scope.resetFilter = resetFilter;
                $scope.openDeleteConfirmation = openDeleteConfirmation;
                $scope.closeDeleteConfirmation = closeDeleteConfirmation;
                $scope.confirmDeleteCustomer = confirmDeleteCustomer;
                $scope.clearAlert = clearAlert;
                $scope.isBusy = isBusy;

                loadCustomers(true);

                function loadCustomers(reset) {
                    $scope.isLoading = true;

                    // Simulate API call delay
                    $timeout(function () {
                        var filtered = dummyCustomers;

                        if ($scope.filter.keyword) {
                            var keyword = $scope.filter.keyword.toLowerCase();
                            filtered = dummyCustomers.filter(function (c) {
                                return c.fullName.toLowerCase().includes(keyword) ||
                                       (c.address1 && c.address1.toLowerCase().includes(keyword)) ||
                                       (c.phoneNumber && c.phoneNumber.toLowerCase().includes(keyword));
                            });
                        }

                        $scope.customers = filtered;
                        $scope.isLoading = false;
                    }, 500);
                }

                function searchCustomers() {
                    if (isBusy()) {
                        return;
                    }

                    clearAlert();
                    loadCustomers(true);
                }

                function resetFilter() {
                    if (isBusy()) {
                        return;
                    }

                    clearAlert();
                    $scope.filter.keyword = '';
                    loadCustomers(true);
                }

                function openDeleteConfirmation(customer) {
                    if (!customer || !customer.customerID) {
                        return;
                    }

                    clearAlert();
                    $scope.deleteModal.customer = customer;
                    $scope.deleteModal.errorMessage = '';
                    $scope.deleteModal.visible = true;
                }

                function closeDeleteConfirmation() {
                    if ($scope.isDeleting) {
                        return;
                    }

                    $scope.deleteModal.visible = false;
                    $scope.deleteModal.customer = null;
                    $scope.deleteModal.errorMessage = '';
                }

                function confirmDeleteCustomer() {
                    var customer = $scope.deleteModal.customer;

                    if (!customer || !customer.customerID) {
                        closeDeleteConfirmation();
                        return;
                    }

                    $scope.isDeleting = true;
                    $scope.deleteModal.errorMessage = '';
                    clearAlert();

                    // Simulate API call
                    $timeout(function () {
                        // Remove from dummy data
                        var index = dummyCustomers.findIndex(function (c) {
                            return c.customerID === customer.customerID;
                        });

                        if (index > -1) {
                            dummyCustomers.splice(index, 1);
                        }

                        var successMessage = 'Customer has been deleted successfully.';
                        $scope.deleteModal.visible = false;
                        $scope.deleteModal.customer = null;
                        $scope.deleteModal.errorMessage = '';
                        $scope.isDeleting = false;

                        loadCustomers(true);
                        showAlert('success', successMessage);
                    }, 800);
                }

                function isBusy() {
                    return $scope.isLoading || $scope.isDeleting;
                }

                function showAlert(type, message) {
                    $scope.alert.type = type;
                    $scope.alert.message = message;

                    if (type === 'success') {
                        $timeout(function () {
                            clearAlert();
                        }, 3500);
                    }
                }

                function clearAlert() {
                    $scope.alert.type = '';
                    $scope.alert.message = '';
                }
            }
        })();
    </script>
}