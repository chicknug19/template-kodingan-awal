@model JPP.Models.Customer.Responses.CustomerDetailViewModel

@{
    ViewData["Title"] = Model.PageTitle;
    ViewData["PageTitle"] = Model.PageTitle;
    ViewData["PageSubtitle"] = Model.PageSubtitle;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var form = Model.Form;
    var disabled = Model.IsReadOnly ? "disabled" : null;
}

<div class="admin-page-header mb-4">
    <div>
        <span class="admin-eyebrow">Customer Module</span>
        <h3>@Model.PageTitle</h3>
        <p>
            Manage customer account and personal information.
        </p>
    </div>

    <div class="admin-page-actions">
        <a href="/Customer/CustomerList/Index"
           class="btn btn-soft">
            <i class="bi bi-arrow-left me-2"></i>
            Back to List
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger" role="alert">
        <strong>Please check your entry.</strong>
        <div asp-validation-summary="All"></div>
    </div>
}

<!-- PERBAIKAN: Arahkan ke Area Customer, Controller CustomerAdd, Action Save -->
<form asp-area="Customer"
      asp-controller="CustomerAdd"
      asp-action="Save"
      method="post"
      id="customerForm">

    @Html.AntiForgeryToken()

    <input type="hidden" name="ID" value="@form.ID" />
    <input type="hidden" name="SubmitMode" id="SubmitMode" value="Save" />

    <div class="employee-form-shell">
        <div class="employee-toolbar crm-card mb-4">
            <div>
                <h5>@(Model.IsEditMode? Model.DisplayName: "New Customer")</h5>
                <p>@(Model.IsEditMode ? $"Customer ID: {form.ID}" : "Complete the customer data below.")</p>
            </div>

            <div class="employee-toolbar-actions">
                @if (!Model.IsReadOnly)
                {
                    <button type="submit"
                            class="btn btn-main"
                            data-submit-mode="Save">
                        <span class="spinner-border spinner-border-sm me-2 d-none employee-save-spinner"></span>
                        <i class="bi bi-save me-2 employee-save-icon"></i>
                        Save
                    </button>

                    <button type="submit"
                            class="btn btn-main-outline"
                            data-submit-mode="SaveAndClose">
                        <span class="spinner-border spinner-border-sm me-2 d-none employee-save-spinner"></span>
                        <i class="bi bi-check2-circle me-2 employee-save-icon"></i>
                        Save And Close
                    </button>
                }

                <a href="/Customer/CustomerList/Index"
                   class="btn btn-soft">
                    Cancel
                </a>
            </div>
        </div>

        <!-- PERBAIKAN: Hanya menampilkan 8 kolom yang ada di Database/Model -->
        <div class="crm-card mb-4">
            <div class="section-title">
                <h5>Personal Information</h5>
                <p>Customer basic personal details.</p>
            </div>

            <div class="row g-3">
                <div class="col-xl-4 col-md-6">
                    <label class="form-label admin-form-label">First Name <span class="text-danger">*</span></label>
                    <input type="text" name="FirstName" value="@form.FirstName" class="form-control" @disabled />
                </div>

                <div class="col-xl-4 col-md-6">
                    <label class="form-label admin-form-label">Middle Name</label>
                    <input type="text" name="MiddleName" value="@form.MiddleName" class="form-control" @disabled />
                </div>

                <div class="col-xl-4 col-md-6">
                    <label class="form-label admin-form-label">Last Name</label>
                    <input type="text" name="LastName" value="@form.LastName" class="form-control" @disabled />
                </div>
            </div>
        </div>

        <div class="crm-card mb-4">
            <div class="section-title">
                <h5>Contact & Address Information</h5>
                <p>Customer contact and residential details.</p>
            </div>

            <div class="row g-3">
                <div class="col-xl-4 col-md-6">
                    <label class="form-label admin-form-label">Phone Number <span class="text-danger">*</span></label>
                    <input type="text" name="PhoneNumber" value="@form.PhoneNumber" class="form-control" @disabled />
                </div>

                <div class="col-xl-4 col-md-6">
                    <label class="form-label admin-form-label">Phone Number 2</label>
                    <input type="text" name="PhoneNumber2" value="@form.PhoneNumber2" class="form-control" @disabled />
                </div>

                <div class="col-xl-4 col-md-6">
                    <label class="form-label admin-form-label">Email Address</label>
                    <input type="email" name="EmailAddress" value="@form.EmailAddress" class="form-control" @disabled />
                </div>

                <div class="col-xl-6 col-md-12">
                    <label class="form-label admin-form-label">Address 1 <span class="text-danger">*</span></label>
                    <input type="text" name="Address1" value="@form.Address1" class="form-control" @disabled />
                </div>

                <div class="col-xl-6 col-md-12">
                    <label class="form-label admin-form-label">Address 2</label>
                    <input type="text" name="Address2" value="@form.Address2" class="form-control" @disabled />
                </div>
            </div>
        </div>
    </div>
</form>

<style>
    .employee-form-shell .crm-card {
        border: 0;
        border-radius: 18px;
        box-shadow: 0 12px 35px rgba(49, 55, 69, .08);
        padding: 1.5rem;
    }

    .employee-toolbar {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        padding: 1.25rem;
    }

        .employee-toolbar h5 {
            margin: 0;
            font-weight: 700;
            color: #313745;
        }

        .employee-toolbar p {
            margin: .25rem 0 0;
            color: #7b8190;
        }

    .employee-toolbar-actions {
        display: flex;
        gap: .75rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .section-title {
        margin-bottom: 1.5rem;
    }

        .section-title h5 {
            margin: 0 0 0.5rem;
            font-weight: 700;
            color: #313745;
        }

        .section-title p {
            margin: 0;
            color: #7b8190;
            font-size: 0.9rem;
        }

    .btn-main-outline {
        border: 1px solid #313745;
        color: #313745;
        background: #fff;
    }

        .btn-main-outline:hover {
            background: #313745;
            color: #fff;
        }

    @@media (max-width: 768px) {
        .employee-toolbar {
            align-items: stretch;
            flex-direction: column;
        }

        .employee-toolbar-actions {
            justify-content: flex-start;
        }
    }
</style>

@section Scripts {
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script>
        (function ($) {
            function setSubmitMode(mode) {
                $('#SubmitMode').val(mode || 'Save');
            }

            function setSavingState(isSaving) {
                var $buttons = $('#customerForm button[type="submit"]');
                $buttons.prop('disabled', isSaving);
                $('.employee-save-spinner').toggleClass('d-none', !isSaving);
                $('.employee-save-icon').toggleClass('d-none', isSaving);
            }

            $('.employee-toolbar-actions button[type="submit"]').on('click', function () {
                setSubmitMode($(this).data('submit-mode'));
            });

            $('#customerForm').on('submit', function () {
                setSavingState(true);
            });
        })(jQuery);
    </script>
}