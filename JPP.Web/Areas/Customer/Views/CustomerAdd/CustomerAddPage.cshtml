@model JPP.Models.Customer.Responses.CustomerDetailViewModel

@{
    ViewData["Title"] = Model.PageTitle;
    ViewData["PageTitle"] = Model.PageTitle;
    ViewData["PageSubtitle"] = Model.PageSubtitle;
    Layout = "~/Views/Shared/_Layout.cshtml";
    <link rel="stylesheet" href="~/css/app.css" />

    var form = Model.Form;
    var disabled = Model.IsReadOnly ? "disabled" : null;
}

<div class="admin-page-header mb-4">
    <div>
        <span class="admin-eyebrow">Customer Module</span>
        <h3>@Model.PageTitle</h3>
        <p>
            Manage customer account and personal information.
        </p>
    </div>

    <div class="admin-page-actions">
        <a href="/Customer/CustomerList/Index"
           class="btn btn-soft">
            <i class="bi bi-arrow-left me-2"></i>
            Back to List
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger" role="alert">
        <strong>Please check your entry.</strong>
        <div asp-validation-summary="All"></div>
    </div>
}

<form action="@Url.Action("Save", "CustomerAdd", new { area = "Customer" })"
      method="post"
      id="customerForm">

    @Html.AntiForgeryToken()

    <input type="hidden" name="ID" value="@form.ID" />
    <input type="hidden" name="SubmitMode" id="SubmitMode" value="Save" />

    <div class="employee-form-shell">
        <div class="employee-toolbar crm-card mb-4">
            <div>
                <h5>@(Model.IsEditMode? Model.DisplayName: "New Customer")</h5>
                <p>@(Model.IsEditMode ? $"Customer ID: {form.ID}" : "Complete the customer data below.")</p>
            </div>

            <div class="employee-toolbar-actions">
                @if (!Model.IsReadOnly)
                {
                    <button type="submit"
                            class="btn btn-main"
                            data-submit-mode="Save">
                        <span class="spinner-border spinner-border-sm me-2 d-none employee-save-spinner"></span>
                        <i class="bi bi-save me-2 employee-save-icon"></i>
                        Save
                    </button>

                    <button type="submit"
                            class="btn btn-main-outline"
                            data-submit-mode="SaveAndClose">
                        <span class="spinner-border spinner-border-sm me-2 d-none employee-save-spinner"></span>
                        <i class="bi bi-check2-circle me-2 employee-save-icon"></i>
                        Save And Close
                    </button>
                }

                <a href="/Customer/CustomerList/Index"
                   class="btn btn-soft">
                    Cancel
                </a>
            </div>
        </div>

        <div class="crm-card mb-4">
            <div class="section-title">
                <h5>Customer Information</h5>
                <p>Complete customer personal, contact, and address details.</p>
            </div>

            <div class="row g-4">
                <div class="col-xl-4 col-md-6">
                    <label class="form-label admin-form-label">First Name <span class="text-danger">*</span></label>
                    <input type="text" name="FirstName" value="@form.FirstName" class="form-control" @disabled />
                    @Html.ValidationMessage("FirstName", "", new { @class = "text-danger small mt-1 d-block" })
                </div>

                <div class="col-xl-4 col-md-6">
                    <label class="form-label admin-form-label">Middle Name</label>
                    <input type="text" name="MiddleName" value="@form.MiddleName" class="form-control" @disabled />
                </div>

                <div class="col-xl-4 col-md-12">
                    <label class="form-label admin-form-label">Last Name</label>
                    <input type="text" name="LastName" value="@form.LastName" class="form-control" @disabled />
                </div>

                <div class="col-12">
                    <hr class="text-muted opacity-25 my-1" />
                </div>


                <div class="col-xl-4 col-md-6">
                    <label class="form-label admin-form-label">Phone Number <span class="text-danger">*</span></label>
                    <!-- Tambahkan placeholder di sini -->
                    <input type="text" name="PhoneNumber" value="@form.PhoneNumber" class="form-control" placeholder="e.g. 8123456789" @disabled />
                    @Html.ValidationMessage("PhoneNumber", "", new { @class = "text-danger small mt-1 d-block" })
                </div>

                @* <div class="col-xl-4 col-md-6">
                    <label class="form-label admin-form-label">Phone Number 2 (Optional)</label>
                    <input type="text" name="PhoneNumber2" value="@form.PhoneNumber2" class="form-control" @disabled />
                </div> *@

                <div class="col-xl-4 col-md-6">
                    <label class="form-label admin-form-label">District <span class="text-danger">*</span></label>
                    <input type="text" name="District" value="@form.District" class="form-control" min="0" placeholder="e.g. Cimanggis" @disabled />
                    @Html.ValidationMessage("District", "", new { @class = "text-danger small mt-1 d-block" })
                </div>

                <div class="col-xl-4 col-md-6">
                    <label class="form-label admin-form-label">Email Address</label>
                    <input type="email" name="EmailAddress" value="@form.EmailAddress" class="form-control" @disabled />
                    @Html.ValidationMessage("EmailAddress", "", new { @class = "text-danger small mt-1 d-block" })
                </div>

                <div class="col-xl-4 col-md-6">
                    <label class="form-label admin-form-label">Address <span class="text-danger">*</span></label>
                    <input type="text" name="Address1" value="@form.Address1" class="form-control" @disabled />
                    @Html.ValidationMessage("Address1", "", new { @class = "text-danger small mt-1 d-block" })
                </div>

                <div class="col-xl-4 col-md-6">
                    <label class="form-label admin-form-label">Age <span class="text-danger">*</span></label>
                    <input type="number" name="Age" value="@form.Age" class="form-control" min="0" placeholder="e.g. 25" @disabled />
                    @Html.ValidationMessage("Age", "", new { @class = "text-danger small mt-1 d-block" })
                </div>

                @* <div class="col-xl-6 col-md-12">
                    <label class="form-label admin-form-label">Address 2</label>
                    <input type="text" name="Address2" value="@form.Address2" class="form-control" @disabled />
                </div> *@

                <div class="col-12">
                    <hr class="text-muted opacity-25 my-1" />
                </div>

                <div class="col-xl-6 col-md-6">
                    <label class="form-label admin-form-label">Event Selection <span class="text-danger">*</span></label>
                    <select name="EventId" class="form-select" @disabled>
                        <option value="">- Please Select Event -</option>
                        @if (Model.EventOptions != null && Model.EventOptions.Any())
                        {
                            foreach (var item in Model.EventOptions)
                            {
                                if (form.EventId != null && item.Value == form.EventId.ToString())
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        }
                    </select>
                    @Html.ValidationMessage("EventId", "", new { @class = "text-danger small mt-1 d-block" })
                </div>

                <div class="col-xl-6 col-md-6">
                    <label class="form-label admin-form-label">Store Selection <span class="text-danger">*</span></label>
                    <select name="StoreId" class="form-select" @disabled>
                        <option value="">- Please Select Store -</option>
                        @if (Model.StoreOptions != null && Model.StoreOptions.Any())
                        {
                            foreach (var item in Model.StoreOptions)
                            {
                                if (form.StoreId != null && item.Value == form.StoreId.ToString())
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        }
                    </select>
                    @Html.ValidationMessage("StoreId", "", new { @class = "text-danger small mt-1 d-block" })
                </div>

                <div class="col-xl-12 col-md-12">
                    <label class="form-label admin-form-label">Account Number</label>
                    <input type="text" id="AccountNumberPreview" name="AccountNumber" value="@form.AccountNumber" class="form-control bg-light" readonly placeholder="Auto-generated after selecting a Store" />
                </div>


            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function ($) {
            function setSubmitMode(mode) {
                $('#SubmitMode').val(mode || 'Save');
            }

            function setSavingState(isSaving) {
                var $buttons = $('#customerForm button[type="submit"]');
                $buttons.prop('disabled', isSaving);
                $('.employee-save-spinner').toggleClass('d-none', !isSaving);
                $('.employee-save-icon').toggleClass('d-none', isSaving);
            }

            $('.employee-toolbar-actions button[type="submit"]').on('click', function () {
                setSubmitMode($(this).data('submit-mode'));
            });

            $('#customerForm').on('submit', function () {
                setSavingState(true);
            });

            $('select[name="StoreId"]').on('change', function () {
            var selectedStoreId = $(this).val();

            if (selectedStoreId) {

                $('#AccountNumberPreview').val('Generating...');


                $.get('/Customer/CustomerAdd/GetPreviewAccountNumber', { storeId: selectedStoreId }, function (data) {

                    $('#AccountNumberPreview').val(data.accountNumber);
                }).fail(function() {
                    $('#AccountNumberPreview').val('Error loading account number');
                });
            } else {

                $('#AccountNumberPreview').val('');
            }
        });



        })(jQuery);
    </script>
}